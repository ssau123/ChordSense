<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/middle_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <LinearLayout
        android:id="@+id/logo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:background="@drawable/rectangle_24dp"
        android:elevation="2dp"
        android:layout_marginRight="12dp"
        android:layout_marginVertical="80dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="@id/middle_guideline">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/logo"
            android:layout_margin="20dp"
            app:tint="?attr/colorPrimary" />
    </LinearLayout>


    <LinearLayout
        android:id="@+id/container3254"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:gravity="center"

        android:orientation="vertical"
        android:layout_marginLeft="12dp"
        app:layout_constraintTop_toTopOf="@id/logo"
        app:layout_constraintBottom_toBottomOf="@id/logo"
        app:layout_constraintLeft_toLeftOf="@id/middle_guideline">
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ChordSense Plus"
            android:textSize="32sp"
            android:textColor="?attr/colorPrimary" />



        <TextView
            android:id="@+id/upgrade_text"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="?attr/colorPrimary"
            android:text="• Unlimited Saving\n• Exclusive Progressions\n• Additional Instruments\n• One Time Purchase" />

        <Button
            android:id="@+id/purchase"
            android:layout_width="160dp"
            android:layout_height="60dp"
            android:text="Purchase"
            android:textSize="20sp"
            android:layout_marginTop="10dp"
            android:background="@drawable/rounded_rectangle" />
    </LinearLayout>




</androidx.constraintlayout.widget.ConstraintLayout>