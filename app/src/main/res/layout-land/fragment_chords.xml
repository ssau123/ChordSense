    <LinearLayout
        android:id="@+id/a12"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="20dp"
        app:layout_constraintBottom_toTopOf="@id/keyboard">

        <ImageButton
            android:id="@+id/octave_down"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/rect_12dp"
            android:src="@drawable/keyboard_arrow_down_24dp_5f6368_fill0_wght300_grad0_opsz24"
            android:layout_marginHorizontal="4dp" />

        <ImageButton
            android:id="@+id/octave_up"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/rect_12dp"
            android:src="@drawable/keyboard_arrow_up_24dp_5f6368_fill0_wght300_grad0_opsz24"
            android:layout_marginHorizontal="4dp" />

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/keyboard"
        android:layout_width="wrap_content"
        android:layout_height="80dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent">
    </androidx.constraintlayout.widget.ConstraintLayout>


