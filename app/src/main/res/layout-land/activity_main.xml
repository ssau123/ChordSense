<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:clipToOutline="false"
    android:paddingTop="0dp"
android:animateLayoutChanges="true">

    <FrameLayout
        android:id="@+id/nav_host"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/toggle_nav_view"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:elevation="5dp"
        android:background="@drawable/north_west_24dp_5f6368_fill0_wght300_grad0_opsz24"
        android:layout_marginBottom="10dp"
        android:layout_marginRight="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <Button
        android:id="@+id/close_nav_view"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/close"
        android:elevation="90dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="@id/nav_view"
        app:layout_constraintRight_toRightOf="@id/nav_view" />

    <com.google.android.material.navigationrail.NavigationRailView
        android:id="@+id/nav_view"
        android:layout_width="100dp"
        android:layout_height="match_parent"
        app:menuGravity="center"
        android:padding="10dp"
        app:itemTextColor="@drawable/nav_bar_color_selector"
        app:itemIconTint="@drawable/nav_bar_color_selector"
        app:labelVisibilityMode="labeled"
        android:elevation="4dp"
        android:background="@drawable/nav_rail1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="parent"
        app:itemActiveIndicatorStyle="@null"

        app:menu="@menu/bottom_nav_menu_free" />


