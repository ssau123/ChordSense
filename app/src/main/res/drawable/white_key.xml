<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="1dp">

        <shape android:shape="rectangle">
            <gradient
                android:centerY="0.5"
                android:startColor="#FFFFFF"
                android:endColor="#F2F2F2"
                android:angle="90"/>
            <corners android:radius="4dp" />
        </shape>
    </item>
</layer-list>