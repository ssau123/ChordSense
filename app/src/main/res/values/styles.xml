<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="nav_view_text">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#999999</item>

    </style>

    <style name="progression_list_item_text">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/inter_regular</item>

    </style>

    <style name="octave_label">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">@font/inter_medium</item>

    </style>

    <style name="note_label">
        <item name="android:textSize">8sp</item>
        <item name="android:textColor">#FFFFFF</item>

    </style>


    <style name="root">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:fontFamily">@font/inter_regular</item>

        <item name="android:textAlignment">center</item>
        <item name="android:textSize">20sp</item>

    </style>
    <style name="extension">
        <item name="android:layout_marginTop">-4dp</item>
        <item name="android:fontFamily">@font/inter_regular</item>

        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textSize">14sp</item>


    </style>
    <style name="degree">
        <item name="android:fontFamily">@font/inter_regular</item>

        <item name="android:paddingTop">10dp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="chord_menu_text">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <style name="chord_builder_text">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <style name="menu_text">
        <item name="android:textSize">20sp</item>
        <item name="android:fontFamily">@font/inter_regular</item>

        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <style name="white_key">
        <item name="android:background">@drawable/white_key_selector</item>
        <item name="android:clickable">true</item>
        <item name="android:stateListAnimator">@animator/button_state_list_anim</item>
        <item name="android:elevation">3dp</item>

    </style>

    <style name="black_key">
        <item name="android:background">@drawable/black_key_selector</item>
        <item name="android:stateListAnimator">@animator/button_state_list_anim</item>
        <item name="android:elevation">4dp</item>
        <item name="android:outlineProvider">none</item>
        <item name="android:clickable">true</item>


    </style>

    <style name="buttonStyle" parent="Base.Theme.ChordSense">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAlignment">center</item>
        <item name="android:elevation">2dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:stateListAnimator">@animator/button_state_list_anim</item>
        <item name="android:clickable">true</item>
        <item name="android:soundEffectsEnabled">false</item>
<!--        <item name="android:foreground">?android:attr/selectableItemBackgroundBorderless</item>-->
    </style>

    <style name="outlinedButton" parent="buttonStyle">
        <item name="android:background">@drawable/button_outlined</item>
        <item name="android:textColor">?attr/colorPrimary</item>

    </style>

    <style name="filledButton" parent="buttonStyle">
        <item name="android:background">@drawable/button</item>
    </style>

    <style name="outlinedBox" parent="buttonStyle">
        <item name="android:layout_width">90dp</item>
        <item name="android:layout_height">90dp</item>
        <item name="android:scaleType">center</item>
        <item name="android:background">@drawable/box_outlined</item>
    </style>

    <style name="filledBox" parent="buttonStyle">
        <item name="android:layout_width">90dp</item>
        <item name="android:layout_height">90dp</item>
        <item name="android:scaleType">center</item>
        <item name="android:background">@drawable/box</item>
    </style>

    <style name="spinnerItemStyle">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">20sp</item>
        <item name="android:layout_centerInParent">true</item>

    </style>

    <style name="setting">
        <item name="android:textSize">20sp</item>
    </style>
<!--    <item name="preferenceCategoryTitleTextColor">?attr/colorPrimary</item>-->

    <style name="SettingsTheme" parent="@style/PreferenceThemeOverlay">
        <item name="preferenceCategoryTitleTextAppearance">@style/setting</item>
        <item name="android:textColorAlertDialogListItem">?attr/colorPrimary</item>
        <item name="android:textColorSecondary">@color/red</item>
        <item name="android:textColorPrimary">@color/purple1</item>
        <item name="android:textColorTertiary">@color/purple1</item>






    </style>
    <style name="CustomPreferenceStyle">
        <item name="android:textColorSecondary">@color/red</item>

    </style>
    <style name="AlertDialogCustom" parent="AlertDialog.AppCompat">
        <item name="colorPrimary">?attr/colorPrimary</item>
        <item name="colorAccent">?attr/colorPrimary</item>
        <item name="android:textColorPrimary">?attr/colorPrimary</item>
        <item name="android:background">?attr/colorOnBackground</item>
    </style>


    <style name="MaterialDialogAlertDark" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="android:textColorPrimary">?colorPrimary</item>
        <item name="android:background">?colorSurface</item>
        <item name="android:textColorAlertDialogListItem">?attr/colorPrimary</item>

    </style>

    <style name="MaterialDialogAlertLight" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="android:background">?colorSurface</item>
        <item name="android:textColorAlertDialogListItem">?attr/colorPrimary</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/black</item>
        <item name="android:textColorTertiary">@color/black</item>
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryDark">@color/black</item>
        <item name="colorAccent">@color/black</item>
        <item name="textColorAlertDialogListItem">@color/black</item>

    </style>

    <style name="tab_text" parent="@android:style/TextAppearance.Widget.TabWidget">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/inter_medium</item>


    </style>


    <style name="App.Custom.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">?attr/indicatorColor</item>

    </style>

    <style name="BtnPressedStyle" parent="Widget.AppCompat.ImageButton">
        <item name="android:iconTint">?attr/colorPrimary</item>

    </style>

</resources>

