<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.chords.ChordsFragment" >

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/keyboard_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.75" />


    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/top_border"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.10" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/bottom_border"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.90" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/middle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/top_guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.25" />

        <ImageButton
            android:id="@+id/octave_down"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/rect_12dp"
            android:src="@drawable/keyboard_arrow_down_24dp_5f6368_fill0_wght300_grad0_opsz24"
            android:layout_marginHorizontal="4dp" />

        <ImageButton
            android:id="@+id/octave_up"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/rect_12dp"
            android:src="@drawable/keyboard_arrow_up_24dp_5f6368_fill0_wght300_grad0_opsz24"
            android:layout_marginHorizontal="4dp" />


    <ImageButton
        android:id="@+id/play"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/play"
        android:background="@drawable/circle"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/keyboard_container"/>

    <Button
        android:id="@+id/sound_preset"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginVertical="10dp"
        android:layout_marginLeft="10dp"        android:background="@drawable/music_note_24dp_5f6368_fill0_wght300_grad_25_opsz24"
        app:layout_constraintTop_toTopOf="@id/top_border"
        app:layout_constraintLeft_toLeftOf="parent" />




    <include android:id="@+id/chord_menu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        layout="@layout/chord_menu1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <HorizontalScrollView
        android:id="@+id/keyboard_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        android:elevation="11dp"
        android:requiresFadingEdge="horizontal"
        android:fadingEdgeLength="0dp"
        android:ellipsize="none"
        android:layout_marginHorizontal="10dp"
        app:layout_constraintHeight_percent="0.1"
        app:layout_constraintTop_toBottomOf="@id/chord_menu"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/keyboard"
            android:layout_width="wrap_content"
            android:layout_height="100dp">
        </androidx.constraintlayout.widget.ConstraintLayout>

    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>