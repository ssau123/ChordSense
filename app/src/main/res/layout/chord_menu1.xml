<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/chord_menu"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:clipChildren="false"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false">


        <!--        <ImageButton-->
        <!--            android:id="@+id/exit_chord_menu"-->
        <!--            android:layout_width="44dp"-->
        <!--            android:layout_height="44dp"-->
        <!--            android:layout_marginLeft="10dp"-->
        <!--            android:background="@drawable/arrow_back_24dp_5f6368_fill0_wght300_grad0_opsz24"-->
        <!--            app:layout_constraintTop_toTopOf="parent"-->
        <!--            app:layout_constraintBottom_toBottomOf="parent"-->

        <!--            app:layout_constraintLeft_toLeftOf="parent" />-->

        <TextView
            android:id="@+id/chord_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:stateListAnimator="@animator/button_state_list_anim"
            android:text="Cmaj"
            android:textSize="48sp"
            android:padding="10dp"
            android:textColor="?attr/colorPrimary"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!--        <ImageButton-->
        <!--            android:id="@+id/show_panel"-->
        <!--            android:layout_width="44dp"-->
        <!--            android:layout_height="44dp"-->
        <!--            android:outlineProvider="none"-->
        <!--            android:translationZ="4500dp"-->
        <!--            android:layout_marginRight="10dp"-->
        <!--            android:background="@drawable/keyboard_arrow_down_24dp_5f6368_fill0_wght300_grad0_opsz24"-->
        <!--            app:layout_constraintTop_toTopOf="parent"-->
        <!--            app:layout_constraintBottom_toBottomOf="parent"-->
        <!--            app:layout_constraintRight_toRightOf="parent" />-->


    </androidx.constraintlayout.widget.ConstraintLayout>



    <com.google.android.material.tabs.TabLayout
        android:id="@+id/chord_menu_tabs"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:gravity="center"
        android:background="@null"
        app:tabTextAppearance="@style/tab_text"
        app:tabTextColor="?attr/textInactiveColor"
        app:tabGravity="fill"
        app:tabMode="fixed"
        app:tabSelectedTextColor="?attr/colorPrimary">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"

            android:layout_height="wrap_content"
            android:text="TONES"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VOICING"/>

    </com.google.android.material.tabs.TabLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/chord_menu_tab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/tones_tab"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/middle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.5" />

            <LinearLayout
                android:id="@+id/labels"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Root"
                    android:textSize="16sp"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="?attr/colorPrimary"
                    android:layout_weight="1"
                    android:textAlignment="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Type"
                    android:textSize="16sp"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="?attr/colorPrimary"
                    android:layout_weight="1"
                    android:textAlignment="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Extension"
                    android:fontFamily="@font/inter_regular"
                    android:textSize="16sp"
                    android:textColor="?attr/colorPrimary"
                    android:layout_weight="1"
                    android:textAlignment="center"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/pickers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/labels">

                <com.github.gzuliyujiang.wheelview.widget.WheelView
                    android:id="@+id/root_picker"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:wheel_cyclicEnabled="true"
                    app:wheel_visibleItemCount="3"
                    app:wheel_itemTextSize="16sp"
                    app:wheel_itemTextSizeSelected="18sp"
                    app:wheel_itemTextColorSelected="?attr/colorPrimary"
                    app:wheel_indicatorEnabled="false" />

                <com.github.gzuliyujiang.wheelview.widget.WheelView
                    android:id="@+id/type_picker"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:wheel_cyclicEnabled="true"
                    app:wheel_visibleItemCount="3"
                    app:wheel_itemTextSize="16sp"
                    app:wheel_itemTextSizeSelected="18sp"
                    app:wheel_itemTextColorSelected="?attr/colorPrimary"
                    app:wheel_indicatorEnabled="false" />

                <com.github.gzuliyujiang.wheelview.widget.WheelView
                    android:id="@+id/extension_picker"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:wheel_cyclicEnabled="true"
                    app:wheel_visibleItemCount="3"
                    app:wheel_itemTextSize="16sp"
                    app:wheel_itemTextSizeSelected="18sp"
                    app:wheel_itemTextColorSelected="?attr/colorPrimary"
                    app:wheel_indicatorEnabled="false" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/voicing_tab"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:clipToOutline="false"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingTop="10dp"

            android:visibility="invisible">

            <LinearLayout
                android:id="@+id/buttons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent">


                <Button
                    android:id="@+id/invert_down"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/keyboard_arrow_down_24dp_5f6368_fill0_wght300_grad0_opsz24"
                    android:alpha="0.6"
                    android:layout_margin="10dp" />


                <Button
                    android:id="@+id/voicing_remove"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/delete_24dp_5f6368_fill0_wght300_grad0_opsz24"
                    android:alpha="0.6"
                    android:layout_margin="10dp" />

                <Button
                    android:id="@+id/voicing_add"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/plus"
                    android:alpha="0.6"

                    android:layout_margin="10dp" />

                <Button
                    android:id="@+id/invert_up"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/keyboard_arrow_up_24dp_5f6368_fill0_wght300_grad0_opsz24"
                    android:alpha="0.6"
                    android:layout_margin="10dp" />


            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/voicing_editor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipToOutline="false"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:scrollbars="none"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@id/buttons"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

<!--            <CheckBox android:id="@+id/octave_bass_checkbox"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:textColor="?attr/colorPrimary"-->
<!--                android:text="Octave Bass"-->
<!--                android:layoutDirection="rtl"-->
<!--                app:layout_constraintLeft_toLeftOf="parent"-->
<!--                app:layout_constraintRight_toRightOf="parent"-->
<!--                app:layout_constraintBottom_toBottomOf="parent"/>-->

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center">



