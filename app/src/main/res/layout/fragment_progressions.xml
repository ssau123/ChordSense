    </androidx.constraintlayout.widget.ConstraintLayout>


    <Button
        android:id="@+id/sound_preset"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginVertical="10dp"
        android:layout_marginRight="4dp"
        android:layout_marginLeft="10dp"
        android:background="@drawable/music_note_24dp_5f6368_fill0_wght300_grad_25_opsz24"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"/>
    <Button
        android:id="@+id/save"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/save_24dp_5f6368_fill0_wght300_grad_25_opsz24"
        android:layout_marginVertical="10dp"
        android:layout_marginHorizontal="4dp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/sound_preset"/>

    <Button
        android:id="@+id/folder"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/folder_24dp_5f6368_fill0_wght300_grad_25_opsz24"
        android:layout_marginVertical="10dp"
        android:layout_marginHorizontal="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/save"/>

    <Button
        android:id="@+id/options"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/options"
        android:layout_marginVertical="10dp"
        android:layout_marginHorizontal="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/folder"/>


    <LinearLayout
        android:id="@+id/progression_panel1"
        android:layout_width="0dp"
        android:layout_height="136dp"
        android:background="@android:color/transparent"
        android:clipChildren="false"
        app:layout_constraintWidth_percent="0.55"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:orientation="horizontal"
        android:layout_marginTop="56dp"
        android:layout_marginHorizontal="10dp"
        app:layout_constraintHeight_percent="0.16"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">
    </LinearLayout>

    <LinearLayout
        android:id="@+id/container"
        android:layout_width="56dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:clipToOutline="false"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="@id/progression_panel1"
        app:layout_constraintBottom_toBottomOf="@id/progression_panel1"
        app:layout_constraintLeft_toRightOf="@id/progression_panel1">
        <ImageButton
            android:id="@+id/transpose_up"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/rect_12dp"
            android:src="@drawable/keyboard_arrow_up_24dp_5f6368_fill0_wght300_grad0_opsz24"
            android:layout_marginVertical="4dp" />

        <ImageButton
            android:id="@+id/transpose_down"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/rect_12dp"
            android:src="@drawable/keyboard_arrow_down_24dp_5f6368_fill0_wght300_grad0_opsz24"
            android:layout_marginVertical="4dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/q"
        android:layout_width="300dp"
        android:layout_height="56dp"
        app:layout_constraintTop_toBottomOf="@id/progression_panel1"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <ImageButton
            android:id="@+id/delete_chord"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/delete"
            android:background="@drawable/circle"
            android:layout_marginRight="30dp" />

        <ImageButton
            android:id="@+id/add_chord"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/add_24dp_5f6368_fill0_wght300_grad0_opsz24"
            android:background="@drawable/circle" />

        <ImageButton
            android:id="@+id/edit_chord"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/edit"
            android:background="@drawable/circle"
            android:layout_marginLeft="30dp" />

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/key_select"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:background="@drawable/rect_12dp"
        android:stateListAnimator="@animator/button_state_list_anim"
        android:gravity="center"
        android:paddingHorizontal="10dp"
        android:layout_marginRight="10dp"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="@id/progression_panel1"
        app:layout_constraintBottom_toBottomOf="@id/progression_panel1"
        app:layout_constraintRight_toLeftOf="@id/progression_panel1">

        <TextView
            android:id="@+id/key_select_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="?attr/colorPrimary"
            android:gravity="center"
            android:text="C Ionian"
            android:fontFamily="@font/inter_regular"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/text_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@android:color/transparent"
            android:gravity="center"
            android:text="G# Ionian"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:src="@drawable/drop_down"
            app:layout_constraintLeft_toRightOf="@id/text_size"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/key_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KEY"
        android:fontFamily="@font/inter_medium"
        android:textColor="@color/grey"
        android:textAlignment="center"
        android:textSize="14sp"
        app:layout_constraintLeft_toLeftOf="@id/key_select"
        app:layout_constraintRight_toRightOf="@id/key_select"
        app:layout_constraintBottom_toTopOf="@id/key_select"/>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/keyboard"
        android:layout_width="wrap_content"
        android:layout_height="80dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:elevation="20dp"
        app:layout_constraintWidth_percent="0.9"
        android:layout_marginBottom="56dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">
    </androidx.constraintlayout.widget.ConstraintLayout>


    <LinearLayout
        android:id="@+id/a12"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="20dp"
        app:layout_constraintBottom_toTopOf="@id/keyboard">

        <ImageButton
            android:id="@+id/octave_down"
            android:visibility="invisible"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/rect_12dp"
            android:src="@drawable/keyboard_arrow_down_24dp_5f6368_fill0_wght300_grad0_opsz24"
            android:layout_marginHorizontal="4dp" />

        <ImageButton
            android:id="@+id/octave_up"
            android:visibility="invisible"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/rect_12dp"
            android:src="@drawable/keyboard_arrow_up_24dp_5f6368_fill0_wght300_grad0_opsz24"
            android:layout_marginHorizontal="4dp" />

    </LinearLayout>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/options_menu"
        android:visibility="invisible"
        android:elevation="34dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:background="?attr/colorSurfaceDim">



        <androidx.constraintlayout.widget.Guideline
            android:id="@id/middle_guideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <Button
            android:id="@+id/close_options_menu"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/close"
            android:backgroundTint="@color/black1"
            android:layout_marginRight="16dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <TextView
                android:id="@+id/bpm_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BPM: 140"
                android:textSize="16sp"
                android:textAlignment="center"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <SeekBar
                android:id="@+id/bpm"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:max="60"
                android:progress="30"
                android:thumbTint="?attr/colorPrimary"
                app:layout_constraintLeft_toLeftOf="@id/bpm_label"
                app:layout_constraintRight_toRightOf="@id/bpm_label"
                app:layout_constraintTop_toBottomOf="@id/bpm_label" />

            <!--            <Button-->
            <!--                android:id="@+id/clear_progression"-->
            <!--                android:layout_width="240dp"-->
            <!--                android:layout_height="48dp"-->
            <!--                android:text="Clear Progression"-->
            <!--                android:layout_marginBottom="20dp"-->
            <!--                app:layout_constraintLeft_toLeftOf="parent"-->
            <!--                app:layout_constraintRight_toRightOf="parent"-->
            <!--                app:layout_constraintBottom_toBottomOf="parent"/>-->

            <ImageButton
                android:id="@+id/clear_progression"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="20dp"
                android:src="@drawable/delete_forever_24dp_5f6368_fill0_wght300_grad0_opsz24"
                android:background="@drawable/circle"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear Progression"
                android:textSize="14sp"
                android:textColor="?attr/colorPrimary"
                android:textAlignment="center"
                android:layout_marginTop="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@id/clear_progression" />
        </LinearLayout>



    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageButton
        android:id="@+id/done"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/check"
        android:background="@drawable/circle"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/keyboard_container"
        app:layout_constraintRight_toRightOf="@id/keyboard_container"
        app:layout_constraintLeft_toLeftOf="@id/keyboard_container"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/key_menu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="20dp"
        android:visibility="invisible"
        android:orientation="vertical"
        android:clickable="true"
        android:gravity="center"
        android:background="?attr/colorSurfaceDim">
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/middle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <Button
            android:id="@+id/close_key_menu"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/close"
            android:backgroundTint="@color/black1"
            android:layout_marginRight="16dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent" />

        <TextView
            android:id="@+id/key1324"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/menu_text"
            android:padding="10dp"
            android:text="Key"
            app:layout_constraintBottom_toTopOf="@id/key_pickers"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent" />

        <LinearLayout
            android:id="@+id/key_pickers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.github.gzuliyujiang.wheelview.widget.WheelView
                android:id="@+id/key_root_picker"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                app:wheel_cyclicEnabled="true"
                app:wheel_visibleItemCount="5"
                app:wheel_itemTextSize="18sp"
                app:wheel_itemTextSizeSelected="20sp"
                app:wheel_itemTextColorSelected="?attr/colorPrimary"
                app:wheel_indicatorEnabled="false"/>

            <com.github.gzuliyujiang.wheelview.widget.WheelView
                android:id="@+id/key_mode_picker"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"

                app:wheel_cyclicEnabled="true"
                app:wheel_visibleItemCount="5"
                app:wheel_itemTextSize="18sp"
                app:wheel_itemTextSizeSelected="20sp"
                app:wheel_itemTextColorSelected="?attr/colorPrimary"
                app:wheel_indicatorEnabled="false" />

        </LinearLayout>


        <ImageButton
            android:id="@+id/key_select_done"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/check"
            android:background="@drawable/circle"
            android:layout_margin="10dp"
            app:layout_constraintTop_toBottomOf="@id/key_pickers"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/progressions_menu"
        android:layout_width="0dp"
        android:layout_height="0dp"

        android:elevation="34dp"
        android:visibility="invisible"
        android:background="?attr/android:colorBackground"
        android:clickable="true"
        android:clipChildren="true"
        android:clipToOutline="false"
        android:clipToPadding="false"


        app:layout_constraintTop_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.06" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/bottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.90" />




        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/saved_progressions_layout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:clipToPadding="true"

            app:layout_constraintDimensionRatio="6:5"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/middle1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.5" />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/progressions_label"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/android:colorBackground"
                android:elevation="2dp"
                android:clipToOutline="false"
                android:clipToPadding="false"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <TextView
                    android:id="@+id/progressions_label1"
                    android:layout_width="10000dp"
                    android:layout_height="wrap_content"
                    android:text="Saved Progressions"
                    style="@style/menu_text"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:elevation="2dp"
                    android:outlineProvider="none"
                    android:padding="10dp"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />



                <Button
                    android:id="@+id/back"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginLeft="10dp"
                    android:elevation="4dp"
                    android:background="@drawable/arrow_back_24dp_5f6368_fill0_wght300_grad0_opsz24"
                    app:layout_constraintTop_toTopOf="@id/progressions_label"
                    app:layout_constraintBottom_toBottomOf="@id/progressions_label"
                    app:layout_constraintLeft_toLeftOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>


            <com.chordsense.chordapp.FadingEdgeRecyclerView
                android:id="@+id/progression_list"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="?attr/android:colorBackground"
                android:outlineProvider="none"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="10dp"

                android:scrollbars="vertical"
                android:overScrollMode="always"
                android:paddingTop="46dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <ImageButton
                android:id="@+id/delete_progression"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/circle"
                android:src="@drawable/delete"
                android:layout_marginRight="48dp"
                android:layout_marginBottom="10dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintRight_toLeftOf="@id/middle1"/>

            <ImageButton
                android:id="@+id/open_progression"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/circle"
                android:layout_marginLeft="48dp"
                android:layout_marginBottom="10dp"
                android:src="@drawable/open_in_new_24dp_5f6368_fill0_wght300_grad0_opsz24"
                app:layout_constraintLeft_toRightOf="@id/middle1"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!--        <LinearLayout-->
        <!--            android:layout_width="wrap_content"-->
        <!--            android:layout_height="wrap_content"-->
        <!--            android:orientation="vertical"-->
        <!--            app:layout_constraintTop_toTopOf="parent"-->
        <!--            app:layout_constraintBottom_toBottomOf="parent"-->
        <!--            app:layout_constraintLeft_toRightOf="@id/saved_progressions_layout">-->

        <!--            <ImageButton-->
        <!--                android:id="@+id/delete_progression"-->
        <!--                android:layout_width="60dp"-->
        <!--                android:layout_height="40dp"-->
        <!--                android:background="@drawable/rounded_rectangle"-->
        <!--                android:src="@drawable/delete"-->
        <!--                android:layout_margin="10dp" />-->

        <!--            <ImageButton-->
        <!--                android:id="@+id/open_progression"-->
        <!--                android:layout_width="60dp"-->
        <!--                android:layout_height="40dp"-->
        <!--                android:background="@drawable/rounded_rectangle"-->
        <!--                android:layout_margin="10dp"-->
        <!--                android:src="@drawable/open_in_new_24dp_5f6368_fill0_wght300_grad0_opsz24" />-->
        <!--        </LinearLayout>-->





    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/purchase_premium"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="invisible"
        android:elevation="34dp"
        android:clickable="true"
        android:background="?attr/android:colorBackground">

        <Button
            android:id="@+id/close_premium"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/close"
            android:backgroundTint="@color/black1"
            android:layout_marginRight="16dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saving is a Premium Feature"
                android:textSize="28sp"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Press continue to learn more."
                android:textSize="18sp"
                android:textColor="?attr/colorPrimary"
                android:layout_marginBottom="10dp"/>
            <Button
                android:id="@+id/purchase"
                android:layout_width="160dp"
                android:layout_height="60dp"
                android:text="Continue"
                android:textSize="20sp"
                android:background="@drawable/rounded_rectangle" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/save_menu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:visibility="invisible"
        android:elevation="34dp"
        android:clickable="true"
        android:background="?attr/colorSurfaceDim">



        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/save_layout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/top1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.2" />

            <TextView
                android:id="@+id/save_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/menu_text"
                android:padding="10dp"
                android:text="Save Progression"
                app:layout_constraintBottom_toTopOf="@id/progression_name"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent" />


            <EditText
                android:id="@+id/progression_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/menu"
                android:layout_marginHorizontal="10dp"
                android:padding="10dp"
                android:textSize="16sp"
                android:textColor="?attr/colorPrimary"
                android:imeOptions="flagNoExtractUi"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/enter_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter a Title"
                android:elevation="14dp"
                android:textColor="?attr/android:textColorPrimary"
                android:layout_marginHorizontal="10dp"
                android:padding="10dp"
                android:textSize="16sp"
                android:clickable="false"
                app:layout_constraintLeft_toLeftOf="@id/progression_name"
                app:layout_constraintRight_toRightOf="@id/progression_name"
                app:layout_constraintTop_toTopOf="@id/progression_name"
                app:layout_constraintBottom_toBottomOf="@id/progression_name"/>




            <ImageButton
                android:id="@+id/confirm_save"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/circle"
                android:src="@drawable/check"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/progression_name"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <Button
            android:id="@+id/cancel_save"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/close"
            android:backgroundTint="@color/black1"
            android:layout_margin="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent" />



    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/chord_menu_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:background="?attr/android:colorBackground"
        android:translationZ="12dp"
        android:visibility="invisible"
        android:clickable="true">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/menu_guideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.15" />


        <include
            android:clipChildren="false"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            app:layout_constraintDimensionRatio="1:1"
            layout="@layout/chord_menu"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />



    </androidx.constraintlayout.widget.ConstraintLayout>


    <LinearLayout
        android:id="@+id/cover"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="45dp"
        android:background="?attr/android:colorBackground"
        android:outlineProvider="none"
        android:visibility="invisible"
        android:gravity="center_horizontal"
        app:layout_constraintBottom_toTopOf="@id/keyboard_container">

        <TextView
            android:id="@+id/chord_name_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="48sp"
            android:layout_marginTop="10dp"
            android:textColor="?attr/colorPrimary"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

    </LinearLayout>






</androidx.constraintlayout.widget.ConstraintLayout>