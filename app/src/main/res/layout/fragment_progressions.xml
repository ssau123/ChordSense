        <View
            android:id="@+id/dim_background"
            android:elevation="3dp"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:background="?attr/colorSurfaceDim">
        </View>


        <ImageButton
            android:id="@+id/exit_chord_menu"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginLeft="10dp"
            android:visibility="invisible"
            android:background="@drawable/arrow_back_24dp_5f6368_fill0_wght300_grad0_opsz24"
            app:layout_constraintTop_toTopOf="@id/chord_name_1"
            app:layout_constraintBottom_toBottomOf="@id/chord_name_1"

            app:layout_constraintLeft_toLeftOf="@id/chord_name_1" />

        <TextView
            android:id="@+id/chord_name_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:text="Cmaj"
            android:textSize="48sp"
            android:padding="10dp"
            android:visibility="invisible"
            android:textColor="?attr/colorPrimary"
            app:layout_constraintLeft_toLeftOf="@id/chord_menu"
            app:layout_constraintRight_toRightOf="@id/chord_menu"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/show_panel"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:outlineProvider="none"
            android:translationZ="4500dp"
            android:layout_marginRight="10dp"
            android:visibility="invisible"
            android:background="@drawable/keyboard_arrow_down_24dp_5f6368_fill0_wght300_grad0_opsz24"
            app:layout_constraintTop_toTopOf="@id/chord_name_1"
            app:layout_constraintBottom_toBottomOf="@id/chord_name_1"

            app:layout_constraintRight_toRightOf="@id/chord_name_1" />
        <LinearLayout
            android:id="@+id/progression_panel"
            android:layout_width="0dp"
            android:layout_height="136dp"
            android:gravity="center_vertical"
            android:background="@drawable/menu"
            android:clipChildren="false"
            android:clipToPadding="true"
            android:layout_gravity="center_vertical"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_marginTop="56dp"
            android:elevation="4dp"
            android:outlineProvider="none"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/progression_view"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:clipToPadding="true"
                android:clipChildren="false"
                android:layout_gravity="center"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                />
